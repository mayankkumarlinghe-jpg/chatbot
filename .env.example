# ============================
# Model Configuration
# ============================
MODEL_NAME=your-huggingface-model
EMBED_MODEL=your-embedding-model

# ============================
# Generation Limits
# ============================
MAX_TOKENS=200

# ============================
# Security
# ============================
ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT=5/minute

# ============================
# Optional (if using private HF model)
# ============================
HF_TOKEN=your_huggingface_token_here